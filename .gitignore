# OS
.DS_Store
Thumbs.db

# Editors / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencies
node_modules/
/vendor

# Dotenv
.env
.env.*
!.env.example

# Bedrock — WordPress core (installed by Composer)
web/wp
web/.htaccess

# Bedrock — uploads, cache, upgrades
web/app/uploads/*
!web/app/uploads/.gitkeep
web/app/cache/*
web/app/upgrade

# WordPress language packs (auto-installed via wp language core install sk_SK)
web/app/languages/

# Bedrock — Composer-installed mu-plugin directories
web/app/mu-plugins/*/

# Bedrock — plugins: ignored by default EXCEPT our own
web/app/plugins/*
!web/app/plugins/.gitkeep
!web/app/plugins/farnost-plugin/

# Bedrock — themes: ignored by default EXCEPT our own
web/app/themes/*
!web/app/themes/farnost-theme/

# Composer auth
auth.json

# PHPUnit / Pest
phpunit.xml
.phpunit.result.cache
.phpunit.cache

# WP-CLI local override
wp-cli.local.yml

# Build artefakty
dist/
build/
*.zip
# Plugin build/ je výstup `npm run build` a patrí do release ZIP-u — tracking povolený.
!web/app/plugins/farnost-plugin/build/
!web/app/plugins/farnost-plugin/build/**

# DDEV — keep config but ignore generated files
.ddev/*
!.ddev/config.yaml
!.ddev/config.*.yaml
