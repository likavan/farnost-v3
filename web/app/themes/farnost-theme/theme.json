{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1200px"
    },
    "color": {
      "palette": [
        { "slug": "background", "color": "#ffffff", "name": "Pozadie" },
        { "slug": "foreground", "color": "#1a1a1a", "name": "Text" },
        { "slug": "primary", "color": "#1e40af", "name": "Primárna" },
        { "slug": "muted", "color": "#6b7280", "name": "Tlmená" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "system",
          "name": "Systémové písmo",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--foreground)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system)",
      "lineHeight": "1.6"
    }
  },
  "templateParts": [
    { "name": "header", "title": "Hlavička", "area": "header" },
    { "name": "footer", "title": "Päta", "area": "footer" }
  ]
}
