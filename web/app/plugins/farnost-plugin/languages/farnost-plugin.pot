#: src/Admin/NavodPage.php:156
msgid "V menu Farnosť → Oznamy. Otvorte rozpracovaný oznam pre nasledujúci týždeň (systém ho pripravuje dopredu sám)."
msgstr ""

#: src/Admin/NavodPage.php:157
msgid "Karty s omšami sú už predvyplnené z rozpisu a úmyslov. Ak treba korekciu, kliknite priamo do bunky."
msgstr ""

#: src/Admin/NavodPage.php:158
msgid "Pod kartami je voľný blok „Bežné oznamy\" — sem píšete pohreby, zbierky, akcie, ďakovania."
msgstr ""

#: src/Admin/NavodPage.php:159
msgid "Riadok „Tento týždeň upratuje\" sa vkladá automaticky podľa aktuálnej skupiny."
msgstr ""

#: src/Admin/NavodPage.php:160
msgid "Stačí uložiť ako Draft — publikuje sa sám v nastavený deň a čas. Nemusíte byť pri počítači."
msgstr ""

#: src/Admin/NavodPage.php:165
msgid "Ako pridať pohreb (alebo sobáš, púť…)"
msgstr ""

#: src/Admin/NavodPage.php:167
msgid "Otvorte Kalendár omší (Farnosť → Kalendár omší)."
msgstr ""

#: src/Admin/NavodPage.php:168
msgid "V príslušnom dni kliknite na „+\" tlačidlo pod existujúcimi omšami."
msgstr ""

#: src/Admin/NavodPage.php:169
msgid "Zadajte čas, kostol, označenie (napr. „pohrebná\") a voliteľne úmysel. Uložte."
msgstr ""

#: src/Admin/NavodPage.php:170
msgid "Pohreb sa automaticky objaví v najbližšom rozpracovanom ozname pre daný týždeň."
msgstr ""

#: src/Admin/NavodPage.php:173
msgid "Toto je „výnimka\" v rozpise — pridaná omša nad rámec pravidelnej. Ak naopak chcete pravidelnú omšu na daný deň zrušiť, použite režim „bez omše\" v kalendári."
msgstr ""

#: src/Admin/NavodPage.php:178
msgid "Ako spravovať úmysly omší"
msgstr ""

#: src/Admin/NavodPage.php:180
msgid "Kalendár omší — kliknite priamo na čas omše v danom dni."
msgstr ""

#: src/Admin/NavodPage.php:181
msgid "V dialógu napíšte úmysel (napr. „† Mária Nováková\" alebo „Za zdravie rodiny\"). Uložte."
msgstr ""

#: src/Admin/NavodPage.php:182
msgid "Ak chcete úmysel skryť na verejnom webe (zostáva len v internej evidencii), zapnite prepínač „Anonymný\"."
msgstr ""

#: src/Admin/NavodPage.php:183
msgid "Úmysly sa potom automaticky vložia do rozpracovaného oznamu pre daný týždeň."
